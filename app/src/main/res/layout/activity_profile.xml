<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED">

    <!-- Back Button -->

    <!-- Title -->


    <!-- Form Container -->
    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="24dp"
        android:background="@drawable/form_container_bg"
        android:padding="16dp"
        android:layout_below="@id/titleText"
        android:layout_marginTop="32dp"
        android:layout_centerHorizontal="true"
        android:gravity="center_horizontal"
        android:elevation="4dp"
        android:layout_marginBottom="80dp"
        android:clipToOutline="true">


    <!-- Profile Image -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/img_14"
            android:layout_marginTop="16dp"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop" />

        <!-- Full Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:text="Dhiyana Thivurani"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="14sp" />

        <!-- Date of Birth -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etDob"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:text="19/06/2003"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="14sp" />

        <!-- Gender -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:text="Female"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="14sp" />

        <!-- Phone -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:text="+9471 2875432"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="14sp" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:text="dhiyana@gmail.com"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:backgroundTint="#CA9C6D"
        android:text="Edit"
        android:textColor="#FFFFFF" />

</RelativeLayout>
