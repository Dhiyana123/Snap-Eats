<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Map Section -->
    <ImageView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:scaleType="centerCrop"
        android:src="@drawable/map" />

    <!-- Order Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delivered your order"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="16dp"
        android:layout_centerHorizontal="true" />

    <!-- Delivery Person Card -->
    <LinearLayout
        android:id="@+id/deliveryPersonCard"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_below="@id/mapView"
        android:orientation="horizontal"
        android:background="#575757"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/deliveryPersonImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/img_13"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/deliveryPersonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cristopert Dastin"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deliveryPersonId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID 213752"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/chat_chat_svgrepo_com"

            android:layout_marginEnd="16dp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/call_receive_svgrepo_com"
             />
    </LinearLayout>

    <!-- Order Info Section -->
    <LinearLayout
        android:id="@+id/orderInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/deliveryPersonCard"
        android:orientation="vertical"
        android:background="#EFEDED"
        android:padding="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Delivery Time"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="16sp"
            android:paddingTop="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estimated 8:30 - 9:15 PM"
            android:textColor="#777777"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Timeline Icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/bag_shopping_svgrepo_com"
                android:layout_marginEnd="24dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/delivery_fast_solid_svgrepo_com"
                android:layout_marginEnd="24dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/done_svgrepo_com"
                 />
        </LinearLayout>

        <!-- Order Items -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Hamburger"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>



</RelativeLayout>
